# Django Debug Mode (1 = enabled, 0 = disabled)
DEBUG=1

# Django Secret Key
# SECURITY: Generate a new random secret key for each environment
# Use: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=REPLACE_WITH_SECRET_KEY

# Allowed hosts for Django (space-separated list)
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1] backend

# Auth0 Configuration
# Get these values from your Auth0 Dashboard → Applications → Your App
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=

# Database Configuration
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=REPLACE_WITH_DB_NAME
SQL_USER=REPLACE_WITH_USERNAME
SQL_PASSWORD=REPLACE_WITH_PASSWORD
SQL_HOST=db
SQL_PORT=REPLACE_WITH_PORT_NO
DATABASE=postgres

# Email settings
# For development with Mailhog: use console backend (prints to stdout)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=mailhog
EMAIL_PORT=1025

# For production with Gmail SMTP relay:
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password # generate this using app passwords, see README
DEFAULT_FROM_EMAIL=djangoreinhardttester@gmail.com
