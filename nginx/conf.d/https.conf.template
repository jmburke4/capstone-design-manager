server {
    listen 8443 ssl http2;
    server_name DOMAIN_NAME www.DOMAIN_NAME;

    ssl_certificate /etc/letsencrypt/live/DOMAIN_NAME/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/DOMAIN_NAME/privkey.pem;

    root /usr/share/nginx/html;
    index index.html;

    # === DJANGO ADMIN PANEL ===
    location /admin/ {
        proxy_pass http://backend:8000/admin/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
    }

    # === DJANGO STATIC FILES - Served directly from shared volume ===
    # Gunicorn doesn't serve static files; nginx serves them directly from the shared volume
    location /static/ {
        alias /usr/share/nginx/staticfiles/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # === MAIN API ===
    location /api/ {
        proxy_pass http://backend:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_pass_header Authorization;
    }

    # Cache Vue static assets (images, JS, CSS from frontend/dist)
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;   # Important: don't fall through to SPA
    }

    # === Vue SPA routing - MUST be last ===
    location / {
        try_files $uri $uri/ /index.html;
    }
}
