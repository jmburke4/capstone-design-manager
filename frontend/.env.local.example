# Auth0 Configuration for Frontend
# Get these values from your Auth0 Dashboard → Applications → Your App

# Auth0 Domain (e.g., dev-abc123.us.auth0.com)
VITE_AUTH0_DOMAIN=your-auth0-domain.auth0.com

# Auth0 Client ID (public identifier for your application)
VITE_AUTH0_CLIENT_ID=your-client-id

# Auth0 API Audience (the API identifier you created in Auth0)
# This should match the backend API identifier
VITE_AUTH0_AUDIENCE=https://your-api-identifier/
